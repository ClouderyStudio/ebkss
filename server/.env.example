# ── 数据库连接（必须保留在 .env，无法从 DB 读取 —— 鸡-蛋问题）──
DB_HOST=156.238.224.129
DB_PORT=3306
DB_NAME=ess
DB_USER=ess
DB_PASSWORD=replace-with-database-password
DB_CONNECTION_LIMIT=10

# ── 以下配置已迁移到数据库 settings 表 ──
# 启动时自动从 DB 加载，.env 中的值作为首次初始化后备。
# 日常修改请在管理后台的「系统设置」Tab 中进行，修改即时生效。
#
# .env 中可保留以下变量作为初始值（仅首次运行且 settings 表为空时写入 DB）：
#   PORT, CLIENT_ORIGIN, SERVE_CLIENT
#   AI_BASE_URL, AI_API_KEY, AI_MODEL, AI_NOTES_MODEL, AI_TIMEOUT_MS
#   SILICONFLOW_API_KEY, SILICONFLOW_LLM_MODEL
#   DASHSCOPE_API_KEY, TTS_MODEL, TTS_VOICE, AUDIO_CACHE_PATH
#   DEFAULT_TTS_SPEED, DEFAULT_TTS_VOLUME
#   DEFAULT_SHOW_TO_ANSWER_DELAY, DEFAULT_ANSWER_HOLD_DELAY
#   AUTH_SECRET, ADMIN_PASSWORD
#
# 优先级：数据库 settings 表 > .env > 代码默认值
